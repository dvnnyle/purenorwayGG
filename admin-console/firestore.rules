rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        "godannyyy@gmail.com"
      ];
    }

    function isPublicReviewSubmission() {
      return request.resource.data.keys().hasOnly([
        "name",
        "location",
        "productTag",
        "text",
        "rating",
        "status",
        "featured",
        "verifiedPurchase",
        "photos",
        "createdAt",
        "updatedAt",
        "reviewedAt",
        "reviewedBy"
      ])
      && request.resource.data.name is string
      && request.resource.data.location is string
      && request.resource.data.productTag is string
      && request.resource.data.text is string
      && request.resource.data.rating is number
      && request.resource.data.rating >= 1
      && request.resource.data.rating <= 5
      && request.resource.data.status == "pending"
      && request.resource.data.featured == false
      && request.resource.data.verifiedPurchase == false
      && request.resource.data.photos is list
      && request.resource.data.photos.size() == 0
      && request.resource.data.reviewedAt == null
      && request.resource.data.reviewedBy == null;
    }

    match /newsArticles/{document=**} {
      allow read: if isAdmin() || resource.data.published == true;
      allow write: if isAdmin();
    }

    match /gallerySlides/{document=**} {
      allow read: if isAdmin() || resource.data.active == true;
      allow write: if isAdmin();
    }

    match /reviews/{document=**} {
      allow read: if isAdmin() || resource.data.status == "approved";
      allow create: if isAdmin() || isPublicReviewSubmission();
      allow update, delete: if isAdmin();
    }
  }
}